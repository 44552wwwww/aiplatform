# ═══════════════════════════════════════════════════════
# InsightForge-AI — Production Environment Template
# ═══════════════════════════════════════════════════════
#
# 使用方法：
#   1. 复制此文件为 .env（项目根目录）：
#      cp .env.production.example .env
#   2. 填入真实的 API Key 和 SECRET_KEY
#   3. 运行：docker compose up -d
#
# ⚠️ 警告：此文件是模板。真实的 .env 永远不要提交到 Git。

# ── Database (Docker: PostgreSQL) ──────────────────────
DATABASE_URL=postgresql://${POSTGRES_USER:-user}:${POSTGRES_PASSWORD:-password}@db:5432/${POSTGRES_DB:-insightforge}
# 本地开发使用 SQLite：
# DATABASE_URL=sqlite:///./insightforge.db

# PostgreSQL 凭证（Docker Compose）
POSTGRES_USER=user
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=insightforge

# ── LLM (Provider-agnostic) ────────────────────────────
# 兼容：OpenAI / DeepSeek / Qwen / OpenRouter / vLLM / Ollama
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.openai.com
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o
LLM_TIMEOUT=120
LLM_API_PATH=/v1/chat/completions

# ── Auth ───────────────────────────────────────────────
SECRET_KEY=your-production-secret-key-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ALGORITHM=HS256

# ── App ────────────────────────────────────────────────
DEBUG=false
CORS_ORIGINS=https://your-frontend-domain.com
# 多个 origin 用逗号分隔：
# CORS_ORIGINS=https://domain1.com,https://domain2.com

# ── Frontend (Docker build arg) ────────────────────────
# Docker 模式下留空（使用 nginx 代理）
# 本地开发模式设为 http://localhost:8000
VITE_API_URL=
