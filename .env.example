# ═══════════════════════════════════════════════════════
# InsightForge-AI — Local Development Environment Template
# ═══════════════════════════════════════════════════════
#
# 使用方法：
#   cp .env.example .env     # (backend/.env 用于本地开发)
#   cp .env.example .env     # (项目根目录用于 Docker)
#
# 生产 / Docker 部署请使用：.env.production.example

# ── Database ───────────────────────────────────────────
# 本地开发：SQLite（零配置，默认）
DATABASE_URL=sqlite:///./insightforge.db
# Docker / 生产：PostgreSQL（需要设置 POSTGRES_* 变量）
# DATABASE_URL=postgresql://${POSTGRES_USER:-user}:${POSTGRES_PASSWORD:-password}@db:5432/${POSTGRES_DB:-insightforge}

# PostgreSQL 凭证（仅 Docker Compose 使用，本地开发可忽略）
POSTGRES_USER=user
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=insightforge

# ── LLM (Provider-agnostic — 切换模型只需改配置，不动代码) ──
# openai_compatible 格式兼容：OpenAI / DeepSeek / Qwen / OpenRouter / vLLM / Ollama
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.openai.com
LLM_API_KEY=your-api-key
LLM_MODEL=gpt-4o
LLM_TIMEOUT=120
LLM_API_PATH=/v1/chat/completions

# ── Auth ───────────────────────────────────────────────
SECRET_KEY=your-secret-key-min-16-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ALGORITHM=HS256

# ── App ────────────────────────────────────────────────
DEBUG=true
CORS_ORIGINS=http://localhost:5173

# ── Frontend ───────────────────────────────────────────
# 本地开发：直接访问后端
VITE_API_URL=http://localhost:8000
# Docker / 生产：留空（nginx 反向代理）
